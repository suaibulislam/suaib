---

---

<div class="timezone-widget">
  <div class="time-display">
    <span class="current-time" id="current-time">loading...</span>
    <span class="timezone-name" id="timezone-name">UTC+6 (Dhaka)</span>
  </div>
  <button class="timezone-toggle" id="timezone-toggle"
    >are we in the same timeline?</button
  >
  <div class="timezone-details" id="timezone-details" style="display: none;">
    <p><strong>my timezone:</strong> UTC+6 (BST)</p>
    <p>
      <strong>your timezone:</strong>
      <span id="visitor-timezone">detecting...</span>
    </p>
    <p>
      <strong>time gap:</strong>
      <span id="time-difference">calculating...</span>
    </p>
  </div>
</div>

<style>
  .timezone-widget {
    text-align: left;
    margin: 3rem 0;
  }

  .time-display {
    margin-bottom: 1.5rem;
  }

  .current-time {
    display: block;
    font-family: "JetBrains Mono", monospace;
    font-size: 1.8rem;
    color: var(--primary-color, #ff8c00);
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .timezone-name {
    color: var(--text-secondary, #a0a0a0);
    font-size: 0.9rem;
  }

  .timezone-toggle {
    background: transparent;
    border: 3px dotted var(--primary-color, #ff8c00);
    color: var(--primary-color, #ff8c00);
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md, 16px);
    cursor: pointer;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    transition: all 0.3s ease;
    margin-bottom: 1rem;
  }

  .timezone-toggle:hover {
    background: transparent;
    color: var(--text-primary);
  }

  .timezone-details {
    background: transparent;
    border: 3px dotted var(--border-color);
    border-radius: var(--radius-lg, 24px);
    padding: 1.5rem;
    max-width: 400px;
    margin: 0;
  }

  .timezone-details p {
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .current-time {
      font-size: 1.5rem;
    }
  }
</style>
