---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-line">
      <span>© {currentYear} suaib</span>
      <span class="sep">/</span>
      <span>made in bangladesh</span>
      <span class="sep">/</span>
      <span
        >it's <a href="/time" id="footer-time" class="footer-time">00:00</a> here</span
      >
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 1rem 0;
    margin-top: 0.5rem;
    border-top: 1px dashed var(--border-color);
  }

  .footer-content {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .footer-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .sep {
    color: var(--primary-color);
    opacity: 0.5;
  }

  .footer-time {
    color: var(--primary-color);
    text-decoration: none;
    border-bottom: 1px dashed var(--border-color);
    transition: all 0.2s ease;
  }

  .footer-time:hover {
    border-bottom-color: var(--primary-color);
    color: var(--text-primary);
  }

  @media (max-width: 600px) {
    .footer-line {
      font-size: 0.75rem;
      gap: 0.5rem;
    }
  }
</style>
