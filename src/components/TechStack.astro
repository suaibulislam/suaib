---
const techItems = [
  "javascript",
  "python",
  "html",
  "css",
  "astro",
  "git",
];
---

<div class="tech-stack">
  <h3 class="tech-heading">stuff i use</h3>
  <div class="tech-list">
    {techItems.map((tech) => <span class="tech-item">{tech}</span>)}
  </div>
</div>

<style>
  .tech-stack {
    margin: 2rem 0 1rem;
  }

  .tech-heading {
    font-family: "Sora", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    text-transform: lowercase;
  }
</style>
