---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const sortedPosts = posts.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );

  return sortedPosts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      prev: index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null,
      next: index > 0 ? sortedPosts[index - 1] : null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={`${post.data.title.toLowerCase()} / suaib`}
  description={post.data.description}
  canonical={`https://suaib.is-a.dev/blogs/${post.slug}`}
>
  <article class="blog-post">
    <header class="post-header">
      <h1 class="post-title" transition:name={`title-${post.slug}`}>
        {post.data.title}
      </h1>
      <div class="post-meta-row">
        <time class="post-date">
          {
            new Date(post.data.date).toLocaleDateString("en-US", {
              month: "long",
              day: "numeric",
              year: "numeric",
            })
          }
        </time>
        <span class="separator">•</span>
        <span class="read-time">5 min read</span>
      </div>
      {
        post.data.tags && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )
      }
    </header>

    <div class="post-content prose-content">
      <Content />
    </div>

    <footer class="post-footer">
      <div class="post-navigation">
        {
          prev ? (
            <a href={`/blogs/${prev.slug}`} class="nav-card prev">
              <span class="nav-label">PREVIOUS</span>
              <span class="nav-title">{prev.data.title}</span>
            </a>
          ) : (
            <div />
          )
        }

        {
          next ? (
            <a href={`/blogs/${next.slug}`} class="nav-card next">
              <span class="nav-label">NEXT</span>
              <span class="nav-title">{next.data.title}</span>
            </a>
          ) : (
            <div />
          )
        }
      </div>

      <div class="post-actions">
        <a href="/blogs" class="back-link">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="19" y1="12" x2="5" y2="12"></line><polyline
              points="12 19 5 12 12 5"></polyline></svg
          >
          back to rants
        </a>
      </div>
    </footer>
  </article>

  <Footer />
</BaseLayout>

<style>
  .blog-post {
    max-width: 700px;
    margin: 0 auto 4rem;
    width: 100%;
  }

  .post-header {
    margin-bottom: 3.5rem;
    padding-bottom: 2.5rem;
    border-bottom: 3px dotted var(--border-color);
  }

  .post-title {
    font-family: 'Lexend', sans-serif;
    font-size: 2.5rem;
    color: var(--primary-color);
    margin-bottom: 1.5rem;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -0.02em;
    word-break: break-word;
    text-transform: lowercase;
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: "Lexend", sans-serif;
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    font-weight: 500;
  }

  .post-tags {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: "Lexend", sans-serif;
    font-size: 0.8rem;
    padding: 0.3rem 0.7rem;
    background: rgba(var(--primary-rgb), 0.05);
    border: 1px dotted var(--primary-color);
    border-radius: 6px;
    color: var(--primary-color);
    font-weight: 600;
  }

  .post-content {
    margin-bottom: 4rem;
  }

  .post-footer {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 3px dotted var(--border-color);
  }

  .post-navigation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 3px dotted var(--border-color);
    border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: transparent;
  }

  .nav-card:hover {
    background: var(--bg-secondary);
    border-color: var(--primary-color);
    transform: translate(-4px, -4px);
    box-shadow: 6px 6px 0 rgba(var(--primary-rgb), 0.2);
    border-radius: 15px 225px 15px 255px / 255px 15px 225px 15px;
  }

  .nav-card.next {
    text-align: right;
  }

  .nav-label {
    display: block;
    font-family: "Lexend", sans-serif;
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .nav-title {
    font-family: "Lexend", sans-serif;
    font-size: 1.1rem;
    color: var(--primary-color);
    font-weight: 700;
    line-height: 1.3;
  }

  .post-actions {
    text-align: center;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-secondary);
    text-decoration: none;
    font-family: "Lexend", sans-serif;
    font-size: 1rem;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--primary-color);
  }

  @media (max-width: 600px) {
    .post-navigation {
      grid-template-columns: 1fr;
    }
    
    .post-title {
      font-size: 2rem;
    }
  }
</style>
