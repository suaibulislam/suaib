---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import TechStack from "../components/TechStack.astro";
---

<BaseLayout
  title="home / suaib"
  description="suaib's personal sketchbook on the web."
  canonical="https://suaib.is-a.dev/"
>
  <section class="about-section">
    <h1 class="section-heading">hello</h1>
    <div class="about-content">
      <p>
        i'm suaib. i watch anime, play clash of clans, and make small things for
        the internet. i don't really have a specialty. i just try stuff until it
        works.
      </p>

      <TechStack />

      <div class="philosophy">
        <h3 class="portal-heading">how i do things</h3>
        <div class="nav-grid portal-grid">
          <div class="nav-card stat-card">
            <div class="nav-icon">!</div>
            <div class="nav-text">
              <div class="nav-title">vibe check</div>
              <div class="nav-desc">i work when i feel like it.</div>
            </div>
          </div>
          <div class="nav-card stat-card">
            <div class="nav-icon">&</div>
            <div class="nav-text">
              <div class="nav-title">the process</div>
              <div class="nav-desc">pure trial and error.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .about-section {
    margin-bottom: 3rem;
  }

  .about-content p {
    font-size: 1rem;
    margin-bottom: 1.5rem;
    max-width: 100%;
    text-align: left;
  }

  .time-signoff {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    font-style: italic;
    opacity: 0.8;
    text-align: center;
  }

  .philosophy {
    margin: 2rem 0;
  }

  .portal-heading {
    font-family: "Outfit", sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 2rem;
    letter-spacing: -0.01em;
    text-align: center;
  }

  .portal-grid {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 240px), 1fr));
  }

  .stat-card {
    background: rgba(var(--primary-rgb), 0.03);
    pointer-events: none;
  }

  .timezone-section {
    margin-top: 4rem;
    margin-bottom: 4rem;
  }
</style>
