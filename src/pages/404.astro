---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="oops zone - suaib"
  description="congrats, you found the void. it's very quiet here. maybe go back to a page that actually exists?"
  canonical="https://suaib.is-a.dev/404"
  hideHeader={true}
>
  <div class="full-page-wrapper">
    <section class="section page-404">
      <div class="error-content">
        <div class="error-visual">
          <div class="error-code">404</div>
          <div class="error-emoji">:)</div>
        </div>

        <h2 class="section-heading">this page does not exist</h2>

        <div class="about-content">
          <p>
            not sure how you got here. sorry about that.
          </p>
        </div>

        <a href="/" class="back-link">← return to home</a>
      </div>
    </section>
  </div>

  <style>
    :global(.main-content) {
      padding: 0 !important;
      max-width: 100% !important;
      margin: 0 !important;
    }

    .full-page-wrapper {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      width: 100%;
      background-color: var(--bg-primary);
      padding: 2rem;
      box-sizing: border-box;
    }
    
    .back-link {
      display: inline-block;
      font-family: "JetBrains Mono", monospace;
      color: var(--primary-color);
      text-decoration: none;
      font-size: 1rem;
      transition: all 0.2s ease;
      margin-top: 2rem;
      border: 1px dashed var(--border-color);
      padding: 0.75rem 1.5rem;
      border-radius: 8px;
    }

    .back-link:hover {
      background: rgba(var(--primary-rgb), 0.05);
      border-color: var(--primary-color);
      transform: translateY(-2px);
    }
  </style>
</BaseLayout>
