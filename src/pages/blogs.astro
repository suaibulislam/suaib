---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const hasPosts = posts.length > 0;
---

<BaseLayout 
  title="rants - suaib" 
  description="sometimes i write things down. when i do, they show up here."
  canonical="https://suaib.is-a.dev/blogs"
>
  <section class="blogs-section">
    <div class="rants-header">
      <h2 class="section-heading">rants</h2>
      <p class="rants-subtitle">sometimes i write things down. when i do, they show up here.</p>
    </div>

    {hasPosts ? (
      <div class="blog-container">
        <div class="search-wrapper">
          <input 
            type="text" 
            id="blog-search" 
            placeholder="search rants..." 
            aria-label="Search blog posts"
          />
        </div>

        <div class="blog-list" id="blog-list">
          {posts.map((post) => (
            <a href={`/blogs/${post.slug}`} class="blog-entry" data-title={post.data.title.toLowerCase()}>
              <span class="blog-title">{post.data.title}</span>
              <span class="blog-date">
                {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </span>
            </a>
          ))}
        </div>

        <div id="no-results" class="empty-state" style="display: none; margin-top: 2rem;">
          <p>nothing matches that. maybe i haven't ranted about it yet.</p>
        </div>
      </div>
    ) : (
      <div class="empty-state">
        <p>nothing here yet. i swear i'll write something eventually.</p>
        <p class="subtle">check back later. or don't. no pressure.</p>
      </div>
    )}
  </section>

  <Footer />
</BaseLayout>

<script>
  const searchInput = document.getElementById('blog-search');
  const blogList = document.getElementById('blog-list');
  const blogEntries = document.querySelectorAll('.blog-entry:not(.drafting)');
  const noResults = document.getElementById('no-results');

  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      let visibleCount = 0;

      blogEntries.forEach((entry) => {
        const title = entry.getAttribute('data-title') || '';
        if (title.includes(query)) {
          (entry as HTMLElement).style.display = 'flex';
          visibleCount++;
        } else {
          (entry as HTMLElement).style.display = 'none';
        }
      });

      if (noResults) {
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    });
  }
</script>

<style>
  .blogs-section {
    margin-bottom: 6rem;
    position: relative;
  }

  .rants-header {
    margin-bottom: 3.5rem;
    position: relative;
  }

  .rants-subtitle {
    font-family: "Lexend", sans-serif;
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin-top: -1.5rem;
    opacity: 0.8;
  }

  .blog-container {
    position: relative;
  }

  .search-wrapper {
    margin-bottom: 3.5rem;
    position: relative;
  }

  .search-doodle {
    position: absolute;
    right: -140px;
    top: 10px;
    font-family: "Lexend", sans-serif;
    color: var(--primary-color);
    font-size: 0.9rem;
    font-style: italic;
    opacity: 0.6;
    white-space: nowrap;
    pointer-events: none;
    transform: rotate(3deg);
  }

  #blog-search {
    width: 100%;
    padding: 1rem 1.4rem;
    background: transparent;
    border: 3px dotted var(--border-color);
    border-radius: var(--radius-md, 10px);
    color: var(--text-primary);
    font-family: "Lexend", sans-serif;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  #blog-search:focus {
    outline: none;
    border-color: var(--primary-color);
    background: rgba(var(--primary-rgb), 0.02);
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .blog-entry {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.75rem 2rem;
    border: 3px dotted var(--border-color);
    border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
    text-decoration: none;
    color: var(--text-primary);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: transparent;
    position: relative;
  }

  .blog-entry:hover {
    background: var(--bg-secondary);
    border-color: var(--primary-color);
    transform: translate(-4px, -4px);
    box-shadow: 6px 6px 0 rgba(var(--primary-rgb), 0.2);
    border-radius: 15px 225px 15px 255px / 255px 15px 225px 15px;
  }

  .blog-entry.drafting {
    opacity: 0.5;
    border-style: dotted;
    cursor: default;
    border-color: var(--border-color);
  }

  .blog-title {
    font-family: "Lexend", sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    text-transform: lowercase;
  }

  .blog-date {
    font-family: "Lexend", sans-serif;
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 500;
    opacity: 0.8;
  }

  @media (max-width: 600px) {
    .blog-entry {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
